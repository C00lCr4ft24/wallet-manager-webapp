{
  "runtime": "Net100",
  "documentGenerator": {
    "fromDocument": {
      "url": "https://localhost:5001/swagger/v1/swagger.json",
      "output": null
    }
  },
  "codeGenerators": {
    "openApiToTypeScriptClient": {
      "typeScriptVersion": "5.9",
      "output": "../WebApp.Client/src/generated/api-client.ts",
      "generateClientClasses": true,
      "generateClientInterfaces": true,
      "separateClientClasses": false,
      "generateDtoClasses": true,
      "excludedParameterNames": [ "cancellationToken" ],
      "useGetBaseUrlMethod": false,
      "baseUrlTokenName": "API_BASE_URL",
      "generateHttpClientInterface": true,
      "httpClientType": "HttpClientFromTypings"
    }
  }
}