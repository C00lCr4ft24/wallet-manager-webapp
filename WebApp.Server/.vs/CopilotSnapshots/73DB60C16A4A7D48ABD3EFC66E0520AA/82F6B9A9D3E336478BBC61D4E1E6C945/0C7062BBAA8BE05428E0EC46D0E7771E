{
  "runtime": "Net100",
  "documentGenerator": {
    "fromDocument": {
      "url": "https://localhost:5001/swagger/v1/swagger.json",
      "output": null
    }
  },
  "codeGenerators": {
    "openApiToTypeScriptClient": {
      //"typeScriptVersion": 5.9,
      "output": "../WebApp.Client/src/generated/api-client.js",
      "generateClientClasses": true,
      "generateClientInterfaces": false,
      "separateClientClasses": true,
      "generateDtoClasses": true,
      "excludedParameterNames": [ "cancellationToken" ],
      "wrapDtoExceptions": true,
      "generateBaseUrlProperty": true,
      "returnType": "Promise"
    }
  }
}