{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",

    "ConnectionStrings": {
        "AppDbConnection": "Server=(localdb)\\webappdb;Database=db;Trusted_Connection=True;"
    },

    "Jwt": {
        "Issuer": "WebApp",
        "Audience": "WebAppUsers",
        "AccessTokenExpirationMinutes": 15,
        "RefreshTokenExpirationDays": 7,
        "CookieDomain": "localhost"
    }
}
